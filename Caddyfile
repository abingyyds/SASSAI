{
	admin off
	persist_config off
	auto_https off
	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:8080} {
	log {
		format json
	}

	encode zstd gzip

	@health path /health
	respond @health "ok" 200

	handle /api/site/* {
		reverse_proxy {$SAAS_BACKEND_URL} {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto https
		}
	}

	handle /api/* {
		reverse_proxy {$SUBROUTER_API_BASE} {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto https
		}
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
